@page "/menu"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing

<PageTitle>Ano imo?</PageTitle>

<div class="kiosk-menu">
    <div class="top-bar">
        <button class="back-btn" @onclick="GoBack">← Back</button>
        <h2>Choose</h2>
        <div class="cart-info">
            Items: @TotalItems | ₱@TotalAmount.ToString("N2")
        </div>
    </div>

    <div class="menu-grid">
        @foreach (var item in MenuItems)
        {
            <div class="menu-item">
                <img src="/images/product.jpg"
                width="100"
                height="100" />
                <h3>@item.Name</h3>
                <p class="price">₱@item.Price</p>

                <div class="quantity-control">
                    <button class="qty-btn" @onclick="() => ChangeQuantity(item, -1)">−</button>
                    <span class="qty">@item.Quantity</span>
                    <button class="qty-btn" @onclick="() => ChangeQuantity(item, 1)">+</button>
                </div>

                <button class="add-to-cart-btn" @onclick="() => AddToCart(item)" disabled="@(item.Quantity == 0)">
                    Add ₱@(item.Subtotal)
                </button>
            </div>
        }
    </div>
</div>

@code {
    private List<MenuItem> MenuItems = new();

    private int TotalItems => MenuItems.Sum(x => x.Quantity);
    private decimal TotalAmount => MenuItems.Sum(x => x.Subtotal);

    protected override void OnInitialized()
    {
        MenuItems = new List<MenuItem>
        {
            new MenuItem { Name = "Bato ni Darna", Price = 99, Image = "/images/product.jpg" }
        };
    }

    private void ChangeQuantity(MenuItem item, int change)
    {
        item.Quantity = Math.Max(0, item.Quantity + change);
        StateHasChanged();
    }

    private void AddToCart(MenuItem item)
    {
        if (item.Quantity > 0)
        {
            var selectedItem = new MenuItem
            {
                Name = item.Name,
                Price = item.Price,
                Quantity = item.Quantity,
                Image = item.Image
            };

            NavigationManager.NavigateTo($"/summary?name={Uri.EscapeDataString(selectedItem.Name)}&price={selectedItem.Price}&quantity={selectedItem.Quantity}");
        }
    }

    private void GoBack() => NavigationManager.NavigateTo("/");

    public class MenuItem
    {
        public string Name { get; set; } = "";
        public decimal Price { get; set; }
        public string Image { get; set; } = "";
        public int Quantity { get; set; } = 0;
        public decimal Subtotal => Price * Quantity;
    }
}
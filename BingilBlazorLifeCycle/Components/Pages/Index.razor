@page "/"

@using Microsoft.AspNetCore.Components

<PageTitle>Jollibee Kiosk</PageTitle>

<div class="welcome-screen">
    <div class="logo">
        <h1>JOLLIBEE</h1>
        <p>Self-Service Kiosk</p>
    </div>

    <h2>How would you like to enjoy your meal?</h2>

    <div class="order-options">
        <button class="option-card" @onclick="() => StartOrder(true)">
    <div class="icon">🍽️</div>
    <h3>DINE IN</h3>
    <p>Eat here</p>
</button>

<button class="option-card" @onclick="() => StartOrder(false)">
    <div class="icon">🛍️</div>
    <h3>TAKE OUT</h3>
    <p>Take home</p>
</button>
    </div>
</div>

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    private void StartOrder(bool isDineIn)
    {
        NavigationManager.NavigateTo("/menu");
    }
}
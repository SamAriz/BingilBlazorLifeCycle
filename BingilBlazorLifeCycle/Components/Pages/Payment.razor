@page "/payment"
@rendermode InteractiveServer
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components

<PageTitle>Payment</PageTitle>

<div class="payment-page">
    <div class="payment-card">
        <h1>Payment</h1>
        <p>Choose a payment method and enter the details.</p>

        <div class="payment-options">
            <button class="btn btn-primary" @onclick="SelectCash">Cash</button>
            <button class="btn btn-outline-primary" @onclick="SelectCard">Card</button>
        </div>

        @if (SelectedMethod == "Cash")
        {
            <div class="payment-form">
                <label class="form-label">Cash Amount</label>
                <input class="form-control" type="number" @bind="CashAmount" />
                <button class="btn btn-success mt-3" @onclick="PayCash">Confirm Cash Payment</button>
            </div>
        }

        @if (SelectedMethod == "Card")
        {
            <div class="payment-form">
                <label class="form-label">ATM Card Number</label>
                <input class="form-control" maxlength="16" @bind="CardNumber" />
                <label class="form-label mt-2">PIN</label>
                <input class="form-control" type="password" maxlength="4" @bind="CardPin" />
                <button class="btn btn-success mt-3" @onclick="PayCard">Confirm Card Payment</button>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(PaymentMessage))
        {
            <div class="alert alert-success mt-3">@PaymentMessage</div>
        }

        @if (ShowReceipt)
        {
            <div class="receipt-card">
                <h3>Receipt</h3>
                <div class="receipt-row">
                    <span>Item</span>
                    <strong>Bato ni Darna</strong>
                </div>
                <div class="receipt-row">
                    <span>Price</span>
                    <strong>₱99.00</strong>
                </div>
                <div class="receipt-row">
                    <span>Payment Method</span>
                    <strong>@SelectedMethod</strong>
                </div>
                <div class="receipt-row">
                    <span>Status</span>
                    <strong>Paid</strong>
                </div>
            </div>

            <div class="payment-actions">
                <button class="btn btn-outline-primary" @onclick="GoToProducts">Go Back to Product</button>
                <button class="btn btn-primary" @onclick="GoHome">Return Home</button>
            </div>
        }
    </div>
</div>

@code {
    private string PaymentMessage { get; set; } = string.Empty;
    private string SelectedMethod { get; set; } = string.Empty;
    private decimal CashAmount { get; set; }
    private string CardNumber { get; set; } = string.Empty;
    private string CardPin { get; set; } = string.Empty;
    private bool ShowReceipt { get; set; }
    private decimal ProductPrice { get; set; } = 99;

    private void SelectCash()
    {
        SelectedMethod = "Cash";
        PaymentMessage = string.Empty;
        ShowReceipt = false;
        StateHasChanged();
    }

    private void SelectCard()
    {
        SelectedMethod = "Card";
        PaymentMessage = string.Empty;
        ShowReceipt = false;
        StateHasChanged();
    }

    private void PayCash()
    {
        if (CashAmount >= ProductPrice)
        {
            PaymentMessage = $"Cash payment accepted. Change: ₱{CashAmount - ProductPrice:N2}";
            ShowReceipt = true;
        }
        else
        {
            PaymentMessage = "Cash payment is not enough.";
            ShowReceipt = false;
        }

        StateHasChanged();
    }

    private void PayCard()
    {
        if (!string.IsNullOrWhiteSpace(CardNumber) && !string.IsNullOrWhiteSpace(CardPin))
        {
            PaymentMessage = "Card payment accepted.";
            ShowReceipt = true;
        }
        else
        {
            PaymentMessage = "Please enter the card number and PIN.";
            ShowReceipt = false;
        }

        StateHasChanged();
    }

    private void GoToProducts() => NavigationManager.NavigateTo("/menu");

    private void GoHome() => NavigationManager.NavigateTo("/");
}
